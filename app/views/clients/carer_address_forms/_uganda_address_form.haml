.row
  .col-sm-3
    = f.input :province_id, collection: @provinces, input_html: { data: { type: 'provinces', 'subaddresses' => ['cities', 'districts', 'subdistricts'] } }
  .col-sm-3
    = f.input :city_id, collection: @cities, input_html: { data: { type: 'cities', 'subaddresses' => ['districts', 'subdistricts'] } }
  .col-sm-3
    = f.input :district_id, collection: @districts, input_html: { data: { type: 'districts', 'subaddresses' => ['subdistricts'] } }
  .col-sm-3
    = f.input :subdistrict_id, collection: @subdistricts.map{|c| [c.name, c.id] }, input_html: { data: { type: 'subdistricts' } }

.col-xs-12.col-sm-6.col-md-4.house_number
  = f.input :house_number, label: t('.house_number'), input_html:{ required: 'true'}
.col-xs-12.col-sm-6.col-md-4
  = f.input :street_number, label: t('.street_number')
