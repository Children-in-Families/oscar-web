.col-xs-12
  .nested-fields
    = f.hidden_field :client_id, value: @client.id
    .row
      .col-xs-12.col-md-3
        = f.input :name
      .col-xs-12.col-md-3
        = f.input :position
      .col-xs-12.col-md-3
        %br/
        = link_to_remove_association t('clients.form.remove_mosavy_official'), f, class: 'm-t-sm btn-remove-official btn btn-xs btn-outline btn-danger'
