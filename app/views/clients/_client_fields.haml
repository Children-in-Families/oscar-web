.nested-fields
  .row
    .col-md-4.col-xs-12
      - if f.object.class.name != 'Client'
        = f.hidden_field :client_id, value: @client.id
        = f.input :name
        = f.input :position
        = link_to_remove_association t('clients.form.remove_mosavy_official'), f, class: 'btn-remove-official btn btn-xs btn-outline btn-danger'
